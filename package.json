{
  "name": "gamaguchi",
  "version": "0.0.1",
  "type": "module",
  "description": "Asset portfolio client",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "electrobun": "1.16.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "solid-js": "^1.9.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  },
  "private": true
}
